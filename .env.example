# Set these in Vercel Dashboard → Settings → Environment Variables
# DO NOT put real keys here

# Required — Claude API for chat responses
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional — Claude model override (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Required — Gemini embeddings for semantic search + dynamic wiki page embeddings
GEMINI_API_KEY=your-gemini-api-key-here

# Optional — Upstash Redis for dynamic wiki updates from conversations
# Without these, wiki is read-only (static JSON fallback)
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token-here
