{
  "builds": [
    { "src": "api/index2.py", "use": "@vercel/python" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index2.py",
      "headers": {
        "Cache-Control": "no-cache, no-store",
        "X-Accel-Buffering": "no"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/index2.py"
    }
  ]
}
